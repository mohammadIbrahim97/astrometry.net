#!/usr/bin/env python3
from __future__ import annotations

import os
import sys
from pathlib import Path


def main() -> int:
    script_path = Path(__file__).resolve()
    repo_root = script_path.parent.parent
    repo_lib = repo_root / "lib" / "python"

    if not repo_lib.is_dir():
        print(f"[ERROR] Repository Python library not found: {repo_lib}", file=sys.stderr)
        return 2

    sys.path.insert(0, str(repo_lib))
    os.environ.setdefault("ASTROBENCH_REPO_ROOT", str(repo_root))

    try:
        from astrometry.benchmark.cli import main as cli_main
    except ModuleNotFoundError as error:
        print("[ERROR] Could not import astrometry.benchmark.cli", file=sys.stderr)
        print(f"[ERROR] repo_lib inserted: {repo_lib}", file=sys.stderr)
        print(f"[ERROR] original error: {error}", file=sys.stderr)
        print("[HINT] Expected file:", file=sys.stderr)
        print(f"       {repo_lib / 'astrometry' / 'benchmark' / 'cli.py'}", file=sys.stderr)
        return 2

    return cli_main()


if __name__ == "__main__":
    raise SystemExit(main())
